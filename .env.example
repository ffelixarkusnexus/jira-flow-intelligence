# Database
DATABASE_URL=sqlite:///backend/data/flow.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/flow

# Jira API
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token
JIRA_JQL=project IN (ABC, DEF) ORDER BY updated DESC
JIRA_PAGE_SIZE=100

# Status taxonomy
ACTIVE_STATUSES='["In Progress", "Review"]'
DONE_STATUSES='["Done", "Closed", "Resolved"]'

# Bottleneck thresholds (defaults match 06_INSIGHTS_ENGINE spec)
# BOTTLENECK_TIME_RATIO_THRESHOLD=1.3
# BOTTLENECK_WIP_RATIO_THRESHOLD=1.2
# BOTTLENECK_THROUGHPUT_DELTA_THRESHOLD=-0.2
# BOTTLENECK_TIME_RATIO_EXTRA_THRESHOLD=1.5
# BOTTLENECK_MIN_SCORE=3

# AI explanation (optional — falls back to deterministic template)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS (backend runtime)
# Region for the Secrets Manager client that fetches the Resend API key.
AWS_REGION=us-east-1

# Transactional email (Resend — ADR-0040)
# Replace the example.com addresses with a domain you have verified in Resend.
RESEND_FROM_ADDRESS=notifications@example.com
# Reply-to header + the support address shown in customer email bodies.
RESEND_REPLY_TO=support@example.com
# "From" for alert-delivery emails; a display name is allowed.
ALERT_FROM_ADDRESS=Jira Flow Intelligence Alerts <alerts@example.com>

# Forge
# Forge app ARI (ari:cloud:ecosystem::app/<uuid>) — the FIT audience.
# Empty disables Forge auth (local/dev only). Get it from the Forge manifest.
FORGE_APP_ID=

# App / vendor identity
# Your public vendor / marketing URL (used in the Connect descriptor).
APP_VENDOR_URL=https://example.com

# Infra (CDK) — set at `cdk deploy` time via env var or `-c <key>=...` context,
# NOT read from this backend .env. Both fall back to documented defaults.
#   ALERT_EMAIL   Recipient to subscribe to the ops-alert SNS topic (surfaced
#                 as the AlertEmailRecipient stack output; subscribe manually
#                 per the runbook). e.g. ALERT_EMAIL=ops@your-domain.com
#   HEALTHZ_HOST  Public host Route 53 pings for the prod /healthz uptime
#                 check. e.g. HEALTHZ_HOST=api.your-domain.com
